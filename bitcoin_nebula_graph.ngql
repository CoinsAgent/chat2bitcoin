-- ============================================================
-- NebulaGraph Schema: Bitcoin Address -> Tx -> Address Graph
-- Purpose:
--   Build a production graph for address path and hop analysis.
--
-- Model:
--   Address --input_to_tx--> Tx --tx_to_output--> Address
--
-- Meaning:
--   input_to_tx:
--     Address appears on the input side of a Bitcoin transaction.
--
--   tx_to_output:
--     Transaction creates an output to an address.
--
-- Important:
--   This model shows transaction-level connection.
--   It does NOT prove exact attribution from a specific input address
--   to a specific output address inside a multi-input/multi-output tx.
-- ============================================================

-- ============================================================
-- 1. Create graph space
-- ============================================================
-- PRODUCTION CONFIGURATION (Updated for High Availability):
--   partition_num = 256:
--     - Optimal for large-scale Bitcoin datasets (100M+ transactions)
--     - Powers of 2 are optimal for hash distribution
--     - Provides better parallelism for query execution
--
--   replica_factor = 2:
--     - CRITICAL FIX from previous replica_factor = 1
--     - Ensures high availability: system survives 1 node failure
--     - Recommended minimum for production deployments
--     - Use replica_factor = 3 for mission-critical systems
--
--   vid_type = FIXED_STRING(100):
--     - Sufficient for all Bitcoin addresses and transaction IDs
--     - Format: "addr:<bitcoin_address>" or "tx:<txid>"
--     - Provides safe headroom for future extensions
-- ============================================================

CREATE SPACE IF NOT EXISTS bitcoin_addr_graph (
  partition_num = 256,
  replica_factor = 2,
  vid_type = FIXED_STRING(100)
);

-- Wait for the space to be ready before running the rest of the file
-- if your NebulaGraph console returns an error immediately after CREATE SPACE.
-- In that case, run:
--   :sleep 10
-- then execute the statements below again.

USE bitcoin_addr_graph;

-- ============================================================
-- 2. Vertex tags
-- ============================================================

-- Address vertex
-- VID format recommendation:
--   addr:<bitcoin_address>
-- Example:
--   addr:bc1qxxxx
CREATE TAG IF NOT EXISTS address (
  address string
);

-- Transaction vertex
-- VID format recommendation:
--   tx:<txid>
-- Example:
--   tx:4d3c...abcd
CREATE TAG IF NOT EXISTS tx (
  txid string,
  hash string,
  block_hash string,
  block_height int64,
  block_time int64
);

-- ============================================================
-- 3. Edge types
-- ============================================================

-- Input-side bridge edge
-- Direction:
--   Address -> Tx
-- Example:
--   addr:A --input_to_tx--> tx:T
--
-- source_index means vin index for input-side rows.
-- utxo_txid / utxo_vout identify the previous UTXO being spent.
CREATE EDGE IF NOT EXISTS input_to_tx (
  direction string,

  txid string,
  hash string,

  block_hash string,
  block_height int64,
  block_time int64,

  utxo_txid string,
  utxo_vout int64,
  source_index int64,

  value double,
  value_delta double,

  revision int64
);

-- Output-side bridge edge
-- Direction:
--   Tx -> Address
-- Example:
--   tx:T --tx_to_output--> addr:C
--
-- source_index means vout index for output-side rows.
-- utxo_txid / utxo_vout identify the newly created UTXO.
CREATE EDGE IF NOT EXISTS tx_to_output (
  direction string,

  txid string,
  hash string,

  block_hash string,
  block_height int64,
  block_time int64,

  utxo_txid string,
  utxo_vout int64,
  source_index int64,

  value double,
  value_delta double,

  revision int64
);

-- ============================================================
-- 4. Optional indexes
-- ============================================================
-- For high-speed traversal by known VID, indexes are not required.
-- Create indexes only if you need property search such as:
--   LOOKUP ON address WHERE address.address == "bc1..."
--   LOOKUP ON tx WHERE tx.block_height == 850000
--
-- Production advice:
--   For very large bulk loading, create/rebuild indexes after loading data.
-- ============================================================

CREATE TAG INDEX IF NOT EXISTS address_addr_index
ON address(address(90));

CREATE TAG INDEX IF NOT EXISTS tx_txid_index
ON tx(txid(90));

CREATE TAG INDEX IF NOT EXISTS tx_block_height_index
ON tx(block_height);

CREATE TAG INDEX IF NOT EXISTS tx_block_time_index
ON tx(block_time);

-- ============================================================
-- 5. Rebuild indexes
-- ============================================================
-- Run these after data is loaded if you use indexes.
-- They are included here for convenience, but for large datasets you may
-- prefer to comment them out during initial schema creation.
-- ============================================================

-- REBUILD TAG INDEX address_addr_index;
-- REBUILD TAG INDEX tx_txid_index;
-- REBUILD TAG INDEX tx_block_height_index;
-- REBUILD TAG INDEX tx_block_time_index;

-- ============================================================
-- 6. Example insert statements
-- ============================================================
-- These are commented out. Use them only for testing.
-- ============================================================

-- INSERT VERTEX address(address)
-- VALUES "addr:A":("A"), "addr:B":("B"), "addr:C":("C"), "addr:D":("D");

-- INSERT VERTEX tx(txid, hash, block_hash, block_height, block_time)
-- VALUES "tx:T":("T", "T", "000000000000", 850000, 1718000000);

-- Inputs:
-- A: 1 BTC
-- B: 2 BTC
-- INSERT EDGE input_to_tx(
--   direction, txid, hash, block_hash, block_height, block_time,
--   utxo_txid, utxo_vout, source_index, value, value_delta, revision
-- )
-- VALUES
--   "addr:A" -> "tx:T"@0:("input", "T", "T", "000000000000", 850000, 1718000000, "prevA", 0, 0, 1.0, -1.0, 0),
--   "addr:B" -> "tx:T"@1:("input", "T", "T", "000000000000", 850000, 1718000000, "prevB", 1, 1, 2.0, -2.0, 0);

-- Outputs:
-- C: 2.5 BTC
-- D: 0.49 BTC
-- INSERT EDGE tx_to_output(
--   direction, txid, hash, block_hash, block_height, block_time,
--   utxo_txid, utxo_vout, source_index, value, value_delta, revision
-- )
-- VALUES
--   "tx:T" -> "addr:C"@0:("output", "T", "T", "000000000000", 850000, 1718000000, "T", 0, 0, 2.5, 2.5, 0),
--   "tx:T" -> "addr:D"@1:("output", "T", "T", "000000000000", 850000, 1718000000, "T", 1, 1, 0.49, 0.49, 0);

-- ============================================================
-- 7. Example traversal queries
-- ============================================================
-- One address-hop:
--   Address -> Tx -> Address
-- ============================================================

-- GO FROM "addr:A"
-- OVER input_to_tx
-- YIELD dst(edge) AS tx_vid
-- | GO FROM $-.tx_vid
--   OVER tx_to_output
--   YIELD dst(edge) AS output_address;

-- Shortest path between two addresses.
-- 1 address-hop = 2 graph steps.
-- 3 address-hops = 6 graph steps.
-- FIND SHORTEST PATH FROM "addr:A" TO "addr:C"
-- OVER input_to_tx, tx_to_output
-- UPTO 6 STEPS;
